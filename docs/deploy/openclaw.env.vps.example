# OpenClaw VPS — exemplo de env file para o container
# Copie para o host (ex.: /home/admin/openclaw.env) e preencha os valores.
# O container é iniciado com: docker run ... --env-file /home/admin/openclaw.env

# -----------------------------------------------------------------------------
# PATH: volume primeiro (bin, uv-tools, npm-global) para persistência
# -----------------------------------------------------------------------------
PATH=/home/node/.openclaw/bin:/home/node/.openclaw/uv-tools/bin:/home/node/.openclaw/npm-global/bin:/home/node/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# -----------------------------------------------------------------------------
# Instalações persistentes no volume (sobrevivem a rebuild do container)
# -----------------------------------------------------------------------------
# uv tool install passa a instalar em ~/.openclaw/uv-tools
UV_TOOL_DIR=/home/node/.openclaw/uv-tools
UV_TOOL_BIN_DIR=/home/node/.openclaw/uv-tools/bin
# npm/pnpm install -g passa a instalar em ~/.openclaw/npm-global
NPM_CONFIG_PREFIX=/home/node/.openclaw/npm-global
# go install passa a colocar binários em ~/.openclaw/bin
GOBIN=/home/node/.openclaw/bin

# -----------------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
OPENCLAW_GATEWAY_BIND=lan

# -----------------------------------------------------------------------------
# Chaves de API (modelos, TTS, etc.)
# -----------------------------------------------------------------------------
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# ELEVENLABS_API_KEY=...
